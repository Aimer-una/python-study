   "source": [
    "import pandas as pd\n",
    "\n",
    "# 读取数据\n",
    "df = pd.read_csv('data/sales.csv',usecols=['订单号','产品类别','产品名称','销售数量','单价'])\n",
    "\n",
    "# 数据处理\n",
    "df['销售金额'] = df['销售数量'] * df['单价']\n",
    "df\n",
    "\n",
    "# 写入数据\n",
    "df.to_csv('data/sales_result.csv',index=False)"
   ],
